generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ====================================================================================
// Tabela: SITE_CONT
// Aplicação: Landing Page TIVOR
// Descrição: Armazena leads capturados via formulário institucional para governança financeira.
// ====================================================================================
model Lead {
  id        String   @id @default(uuid()) @map("UUID_CONT")
  name      String   @map("NOME_CONT")
  email     String   @map("MAIL_CONT")
  company   String?  @map("EMPR_CONT")
  message   String   @map("MENS_CONT")
  
  // Auditoria Técnica (Senior Master)
  ip        String?  @map("IP_CONT")
  userAgent String?  @map("UA_CONT")
  
  // Controle de AuditTrail
  createdAt DateTime @default(now()) @map("CREA_CONT")
  updatedAt DateTime @updatedAt @map("TIME_CONT")

  @@index([email], name: "idx_site_cont_mail")
  @@map("SITE_CONT")
}

// ------------------------------------------------------------------------------------
// Tabelas Introspectadas (PRESERVAR)
// ------------------------------------------------------------------------------------
model AVALIAR {
  id       Int        @id @default(autoincrement())
  FUNC_AVA String?
  LAT1_AVA String?
  LAT2_AVA String?
  LAT3_AVA String?
  STA1_AVA Int?       @default(0)
  STA2_AVA Int?       @default(0)
  STA3_AVA Int?       @default(0)
  CATE_AVA String?
  GEST_AVA String?
  STAG_AVA Int?       @default(0)
  STAF_AVA Int?       @default(0)
  NOTA_AVA NOTA_AVA[]
}

model NOTA_AVA {
  id       Int       @id @default(autoincrement())
  ID_AVA   Int?
  ID_PERG  Int?
  LATR_AVA String?
  NOTA_NOT Int?      @default(0)
  JUST_NOT String?
  DTA_NOT  DateTime? @default(now()) @db.Timestamptz(6)
  AVALIAR  AVALIAR?  @relation(fields: [ID_AVA], references: [id], onDelete: NoAction, onUpdate: NoAction)
  PERG_AVA PERG_AVA? @relation(fields: [ID_PERG], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([ID_AVA, ID_PERG, LATR_AVA], name: "idx_nota_ava_unique")
}

model PERG_AVA {
  id        Int        @id @default(autoincrement())
  ANOE_PERG Int?       @default(0)
  PERG_PERG String?
  PERF_PERG String?
  CATE_PERG String?
  NOTA_AVA  NOTA_AVA[]
}
